{
  "name": "my-postit",
  "version": "1.0.0",
  "description": "A simple desktop sticky note application",
  "main": "main.js",
  "scripts": {
    "start": "node launch.js",
    "dev": "node launch.js",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "keywords": [
    "electron",
    "sticky",
    "note",
    "desktop"
  ],
  "author": "Myself",
  "license": "MIT",
  "build": {
    "appId": "com.mypostit.app",
    "productName": "MyPostit",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "launch.js",
      "index.html",
      "formatter.html",
      "manager.html",
      "calendar.html",
      "history.html",
      "codesnippet.html",
      "notification.html",
      "password.html",
      "properties.html",
      "src/**/*",
      "lang/**/*",
      "img/**/*",
      "node_modules/marked/**/*",
      "node_modules/highlight.js/**/*"
    ],
    "win": {
      "icon": "img/postit.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "MyPostit-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2"
  }
}
